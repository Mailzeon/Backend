# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Get this from: Atlas Dashboard → Connect → Drivers → Copy connection string
# Replace <username>, <password>, and <cluster> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/marketplace?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. You can generate one at: https://generate-secret.vercel.app/32
JWT_SECRET=replace_this_with_a_random_32_char_secret_key
JWT_EXPIRES_IN=7d

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ────────────────────────────────────────────────────────────────────
# In development this is localhost:3000. In production: your Vercel URL
FRONTEND_URL=http://localhost:3000
